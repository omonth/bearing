# 生产环境变量。复制为 .env.production；该文件必须保持私有，不能提交。
# 启动时使用：docker compose --env-file .env.production up -d --build
# 留空的变量是必填项，Compose 会拒绝启动，避免回退到公开默认密钥。
# 密钥推荐使用：openssl rand -base64 48

NODE_ENV=production
LOG_LEVEL=info

# PostgreSQL（DB_USER 和 DB_NAME 可以按组织命名；密码必须是强随机值）
DB_USER=bearing_admin
DB_NAME=bearing_sales
DB_PASSWORD=

# Redis
REDIS_PASSWORD=

# 面向浏览器的公开商城源，例如 https://shop.example.com；不要使用尾随斜杠。
CORS_ORIGIN=

# 主认证与 AI 认证必须彼此独立，均使用至少 32 字符的强随机值。
JWT_SECRET=
AI_JWT_SECRET=

# 仅用于首次初始化管理员账户。用户名和密码均必须显式填写；
# 密码不得复用、不得使用示例值，首次初始化后应安全轮换。
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
AI_BOOTSTRAP_USERNAME=
AI_BOOTSTRAP_PASSWORD=

# 生产环境必须显式设置为 production，不能运行沙箱支付。
PAYMENT_MODE=production

# 可选：CI 部署时以提交 SHA 或镜像摘要覆盖这些变量；手动从源构建可保持为空。
BACKEND_IMAGE=
FRONTEND_IMAGE=
VECTOR_SERVICE_IMAGE=

# 可选能力
DEEPSEEK_API_KEY=

# 仅填写实际启用的支付提供方的生产凭据和 HTTPS 回调地址。
# ALIPAY_MODE / UNIONPAY_MODE 必须保持 production；证书路径应指向运行时只读 Secret 挂载。
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_MODE=production
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY_V3=
WECHAT_CERT_SERIAL=
WECHAT_PRIVATE_KEY=
WECHAT_NOTIFY_URL=
WECHAT_PLATFORM_CERT_PATH=
UNIONPAY_MERCHANT_ID=
UNIONPAY_CERT_PATH=
UNIONPAY_CERT_PWD=
UNIONPAY_VERIFY_CERT_PATH=
UNIONPAY_ENCRYPT_CERT_PATH=
UNIONPAY_NOTIFY_URL=
UNIONPAY_FRONT_URL=
UNIONPAY_MODE=production

# 灰度发布配置
GRAY_RELEASE_ENABLED=false
GRAY_RELEASE_PERCENTAGE=0
GRAY_RELEASE_VARIANT=canary
GRAY_RELEASE_FORCE_HEADER=x-gray-release
