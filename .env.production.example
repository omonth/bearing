# 生产环境变量。复制为 .env.production；该文件必须保持私有，不能提交。
# 启动时使用：docker compose --env-file .env.production up -d --build
# 留空的变量是必填项，Compose 会拒绝启动，避免回退到公开默认密钥。
# 密钥推荐使用：openssl rand -base64 48

NODE_ENV=production
PUBLIC_SITE_URL=https://shop.example.com
LOG_LEVEL=info
CUSTOMER_SECURITY_PEPPER=
CUSTOMER_NOTIFICATION_WEBHOOK_URL=https://notifications.example.com/customer
CUSTOMER_NOTIFICATION_WEBHOOK_TOKEN=

# Encrypted PostgreSQL backup (these are host paths; never commit the files).
BACKUP_ENCRYPTION_KEY_PATH=/etc/bearing-sales/backup-aes-key.base64
BACKUP_AWS_CREDENTIALS_PATH=/etc/bearing-sales/aws-credentials
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=bearing-sales/postgres
BACKUP_S3_REGION=
BACKUP_S3_ENDPOINT=https://s3.example.com
BACKUP_ALERT_WEBHOOK_URL=https://alerts.example.com/hooks/database-backup

# 生产告警必须投递到 HTTPS webhook；阈值会在启动时校验。
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_MS=3000
CALLBACK_SIGNATURE_FAILURE_THRESHOLD=5
ALERT_HTTP_WINDOW_SIZE=100
ALERT_HTTP_MIN_SAMPLES=20
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_LATENCY_THRESHOLD_MS=2000

# PostgreSQL（DB_USER 和 DB_NAME 可以按组织命名；密码必须是强随机值）
DB_USER=bearing_admin
DB_NAME=bearing_sales
DB_PASSWORD=

# Redis
REDIS_PASSWORD=

# 面向浏览器的公开商城源，例如 https://shop.example.com；不要使用尾随斜杠。
CORS_ORIGIN=

# 主认证与 AI 认证必须彼此独立，均使用至少 32 字符的强随机值。
JWT_SECRET=
AI_JWT_SECRET=

# 仅用于首次初始化管理员账户。用户名和密码均必须显式填写；
# 密码不得复用、不得使用示例值，首次初始化后应安全轮换。
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
AI_BOOTSTRAP_USERNAME=
AI_BOOTSTRAP_PASSWORD=

# 生产环境必须显式设置为 production，不能运行沙箱支付。
PAYMENT_MODE=production

# 可选：CI 部署时以提交 SHA 或镜像摘要覆盖这些变量；手动从源构建可保持为空。
# 健康部署后 CI 会原子写入被 Git 忽略的 `.release-images.env`。任何手工
# Compose 操作都必须同时传入 `--env-file .env.production --env-file .release-images.env`。
BACKEND_IMAGE=
FRONTEND_IMAGE=
ADMIN_IMAGE=
VECTOR_SERVICE_IMAGE=

# 可选能力
DEEPSEEK_API_KEY=

# 仅填写实际启用的支付提供方的生产凭据和 HTTPS 回调地址。
# ALIPAY_MODE / UNIONPAY_MODE 必须保持 production；证书路径应指向运行时只读 Secret 挂载。
PAYMENT_CERTIFICATES_DIR=/etc/bearing-sales/payment-certificates
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_MODE=production
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY_V3=
WECHAT_CERT_SERIAL=
WECHAT_PRIVATE_KEY=
WECHAT_MERCHANT_PUBLIC_KEY=
WECHAT_NOTIFY_URL=
WECHAT_PLATFORM_CERT_PATH=
WECHAT_CALLBACK_MAX_AGE_SECONDS=300
UNIONPAY_MERCHANT_ID=
UNIONPAY_CERT_PATH=
UNIONPAY_CERT_PWD=
UNIONPAY_VERIFY_CERT_PATH=
UNIONPAY_ENCRYPT_CERT_PATH=
UNIONPAY_NOTIFY_URL=
UNIONPAY_FRONT_URL=
UNIONPAY_MODE=production

# 灰度发布配置
GRAY_RELEASE_ENABLED=false
GRAY_RELEASE_PERCENTAGE=0
GRAY_RELEASE_VARIANT=canary
GRAY_RELEASE_FORCE_HEADER=x-gray-release
