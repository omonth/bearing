# 环境变量配置（生产环境）
# 复制此文件为 .env.production 并修改相应值

# 数据库配置
DB_USER=bearing_admin
DB_PASSWORD=your_secure_database_password_here
DB_NAME=bearing_sales

# Redis配置
REDIS_PASSWORD=your_secure_redis_password_here

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# CORS配置
CORS_ORIGIN=https://yourdomain.com

# Gray release config
GRAY_RELEASE_ENABLED=false
GRAY_RELEASE_PERCENTAGE=0
GRAY_RELEASE_VARIANT=canary
GRAY_RELEASE_FORCE_HEADER=x-gray-release

# 其他配置
NODE_ENV=production
LOG_LEVEL=info
