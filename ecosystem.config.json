{
  "apps": [{
    "name": "bearing-sales-backend",
    "script": "./server.js",
    "cwd": "./backend",
    "instances": 1,
    "exec_mode": "cluster",
    "env": {
      "NODE_ENV": "production",
      "PORT": 3001
    },
    "error_file": "./logs/pm2-error.log",
    "out_file": "./logs/pm2-out.log",
    "log_date_format": "YYYY-MM-DD HH:mm:ss",
    "merge_logs": true,
    "autorestart": true,
    "max_restarts": 10,
    "min_uptime": "10s",
    "max_memory_restart": "500M",
    "cron_restart": "0 3 * * *"
  }]
}
