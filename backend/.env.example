# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置
# 使用 SQLite（开发环境）
DB_TYPE=sqlite
DB_PATH=./bearings.db

# 使用 PostgreSQL（生产环境）
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=bearing_sales
# DB_USER=bearing_admin
# DB_PASSWORD=your_secure_password

# CORS配置
CORS_ORIGIN=http://localhost:3000

# Gray release config
GRAY_RELEASE_ENABLED=false
GRAY_RELEASE_PERCENTAGE=0
GRAY_RELEASE_VARIANT=canary
GRAY_RELEASE_FORCE_HEADER=x-gray-release

# JWT认证配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=24h

# AI 认证与首次管理员引导。生产环境必须使用独立的强随机 AI_JWT_SECRET，
# 并通过 INITIAL_ADMIN_* / AI_BOOTSTRAP_* 显式提供首次账户凭据。
AI_JWT_SECRET=
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
AI_BOOTSTRAP_USERNAME=
AI_BOOTSTRAP_PASSWORD=

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 备份配置
BACKUP_DIR=./backups
BACKUP_INTERVAL=86400000

# Redis配置（缓存系统）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 库存预警阈值
LOW_STOCK_THRESHOLD=10

# 邮件通知配置
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
ADMIN_EMAIL=admin@bearing-sales.com

# ==================== 支付配置 ====================
# 支付模式: sandbox（沙箱）| production（生产）
PAYMENT_MODE=sandbox

# ---------- 支付宝 ----------
# 申请地址: https://open.alipay.com
ALIPAY_APP_ID=
# 应用私钥（RSA2 2048位，一行字符串，去掉头尾 -----）
ALIPAY_PRIVATE_KEY=
# 支付宝公钥（用于验证回调签名）
ALIPAY_PUBLIC_KEY=
# 异步通知地址（需公网可访问）
ALIPAY_NOTIFY_URL=http://your-domain.com/api/payment/alipay/notify
# 证书模式（可选，优先级高于公钥模式）
# ALIPAY_APP_CERT_PATH=
# ALIPAY_ALIPAY_CERT_PATH=
# ALIPAY_ROOT_CERT_PATH=

# ---------- 微信支付 ----------
# 申请地址: https://pay.weixin.qq.com
WECHAT_APP_ID=
WECHAT_MCH_ID=
# APIv3 密钥
WECHAT_API_KEY_V3=
# 商户证书序列号
WECHAT_CERT_SERIAL=
# 商户API私钥（apiclient_key.pem 文件内容，一行字符串）
WECHAT_PRIVATE_KEY=
# 异步通知地址（需公网可访问）
WECHAT_NOTIFY_URL=http://your-domain.com/api/payment/wechat/notify

# ---------- 银联（银联网关支付）----------
# 申请地址: https://open.unionpay.com
UNIONPAY_MERCHANT_ID=
# 签名证书路径（商户签名私钥 .pfx 文件）
UNIONPAY_CERT_PATH=
# 签名证书密码
UNIONPAY_CERT_PWD=
# 验证签名证书路径（银联公钥 .cer 文件）
UNIONPAY_VERIFY_CERT_PATH=
# 异步通知地址
UNIONPAY_NOTIFY_URL=http://your-domain.com/api/payment/unionpay/notify
# 前台跳转地址
UNIONPAY_FRONT_URL=http://localhost:3000

