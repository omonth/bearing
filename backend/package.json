{
  "name": "bearing-sales-backend",
  "version": "1.0.0",
  "description": "轴承销售系统后端API",
  "main": "server.js",
  "scripts": {
    "start": "node scripts/migrate.js apply && node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/migrate.js apply",
    "backup": "node backup.js",
    "prod": "NODE_ENV=production npm start",
    "migrate": "node scripts/migrate.js apply",
    "migrate:check": "node scripts/migrate.js check",
    "migrate:rollback-compat": "node scripts/checkMigrationRollbackCompatibility.js",
    "migrate:status": "node scripts/migrate.js status",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "migrate:test": "vitest run test/migrations.test.ts test/migrationRollbackCompatibility.test.ts",
    "lint": "eslint . --ext .js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "8.3.0",
    "alipay-sdk": "^4.14.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "file-type": "^21.3.4",
    "helmet": "^8.1.0",
    "i18next": "^26.0.8",
    "i18next-fs-backend": "^2.6.5",
    "i18next-http-middleware": "^3.9.6",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "9.0.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "sqlite3": "6.0.1",
    "wechatpay-node-v3": "^2.2.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "socket.io-client": "4.8.3",
    "supertest": "^7.2.2",
    "vitest": "4.1.10"
  }
}
